# ==========================================
# Configurações do Banco de Dados (MariaDB)
# ==========================================
# Lembrete: O '$' é escapado como '$$' para o Docker Compose não bugar.
# O '@' da senha é encodado como '%40' para a URL do Prisma não quebrar.
DATABASE_URL="mysql://usuario:senha@localhost:3306/dbLojista"

# ─── Sincronização dim_lojas → fat_loja_cadastro ─────────────────────────────
# Mesmo servidor MariaDB, mesmas credenciais — usa queries cross-database
DB_SYNC_HOST=127.0.0.1
DB_SYNC_PORT=3306
DB_SYNC_USER=usuario
DB_SYNC_PASS=senha

# ==========================================
# Configurações do Backend (Fastify)
# ==========================================
PORT=3333
# Troque essa chave em produção por um hash forte
JWT_SECRET="sua_chave_jwt_super_secreta_aqui" 

# ==========================================
# Configurações do Frontend (React/Vite)
# ==========================================
# URL base para o frontend se comunicar com o Fastify
VITE_API_URL="http://localhost:3333"